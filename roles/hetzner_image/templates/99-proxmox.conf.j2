# {{ ansible_managed }}
# Proxmox VE sysctl settings

# Enable IP forwarding for VM networking
net.ipv4.ip_forward = 1
{% if hetzner_image_main_ipv6 | default('') | length > 0 %}
net.ipv6.conf.all.forwarding = 1
{% endif %}

# Disable IPv6 on physical interface (use bridge instead)
net.ipv6.conf.default.disable_ipv6 = 1

# Increase conntrack table for NAT
net.netfilter.nf_conntrack_max = 131072
